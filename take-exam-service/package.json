{
	"name": "take-exam-service",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3002",
		"build": "next build",
		"start": "next start -p 3002",
		"lint": "next lint",
		"codegen": "graphql-codegen --config codegen.mjs",
		"codegen:watch": "graphql-codegen --config codegen.mjs --watch",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"reset:student-data": "node scripts/reset-student-data.mjs --remote",
		"reset:student-data:all": "node scripts/reset-student-data.mjs --remote --include-students",
		"reset:student-data:local": "node scripts/reset-student-data.mjs --local"
	},
	"dependencies": {
		"@apollo/client": "^4.1.6",
		"@aws-sdk/client-s3": "^3.1021.0",
		"@aws-sdk/s3-request-presigner": "^3.1021.0",
		"@opennextjs/cloudflare": "^1.17.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.1",
		"embla-carousel-react": "^8.6.0",
		"graphql": "^16.13.1",
		"graphql-yoga": "^5.18.1",
		"html2canvas": "^1.4.1",
		"html-to-image": "^1.11.13",
		"input-otp": "^1.4.2",
		"katex": "^0.16.22",
		"lucide-react": "^1.7.0",
		"next": "16.1.5",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "19.1.5",
		"react-day-picker": "^9.14.0",
		"react-dom": "19.1.5",
		"react-resizable-panels": "^4.7.6",
		"shadcn": "^4.1.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.2.1",
		"@graphql-codegen/typed-document-node": "^6.1.7",
		"@graphql-codegen/typescript": "^5.0.9",
		"@graphql-codegen/typescript-operations": "^5.0.9",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.5.0",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.76.0"
	}
}
