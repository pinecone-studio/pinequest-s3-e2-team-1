    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.13.2",
    "input-otp": "^1.4.2",
    "katex": "^0.16.42",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
