{
	"name": "my-next-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3001",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"deploy:exam-schedule-consumer": "wrangler deploy -c workers/exam-schedule-consumer/wrangler.toml",
		"dev:exam-schedule-consumer": "wrangler dev -c workers/exam-schedule-consumer/wrangler.toml",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"codegen": "graphql-codegen --config codegen.ts",
		"codegen:watch": "graphql-codegen --config codegen.ts --watch",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate:local": "wrangler d1 migrations apply create-exams --local",
		"db:migrate:remote": "wrangler d1 migrations apply create-exams --remote",
		"db:seed:ai-exam-mock:generate": "bun run scripts/generate-ai-exam-mock-seed.ts",
		"db:seed:ai-exam-mock:local": "wrangler d1 execute create-exams --local --file=./drizzle/seed/ai_exam_mock_seed.sql",
		"db:seed:ai-exam-mock:remote": "wrangler d1 execute create-exams --remote --file=./drizzle/seed/ai_exam_mock_seed.sql",
		"db:seed:scheduler-twin:local": "wrangler d1 execute create-exams --local --file=./drizzle/seed/scheduler_digital_twin_seed.sql",
		"db:seed:scheduler-twin:remote": "wrangler d1 execute create-exams --remote --file=./drizzle/seed/scheduler_digital_twin_seed.sql"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1017.0",
		"@aws-sdk/s3-request-presigner": "^3.1017.0",
		"@google/generative-ai": "^0.24.1",
		"@opennextjs/cloudflare": "^1.17.1",
		"drizzle-orm": "^0.45.1",
		"graphql": "^16.13.1",
		"graphql-yoga": "^5.18.1",
		"hono": "^4.12.9",
		"next": "16.1.5",
		"react": "19.1.5",
		"react-dom": "19.1.5",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@graphql-codegen/cli": "^6.2.1",
		"@graphql-codegen/typescript": "^5.0.9",
		"@graphql-codegen/typescript-resolvers": "^5.1.7",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.5.0",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.76.0"
	}
}