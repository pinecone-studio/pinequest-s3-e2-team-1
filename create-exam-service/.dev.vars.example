# Хуулаад `.dev.vars` болгон нэрлэнэ (.gitignore-д байгаа тул git-д орохгүй).
# Локал:
# - `wrangler` / OpenNext preview үед `.dev.vars` уншигдана
# - `bun run dev` (`next dev`) үед `.env.local`-д бас ижил утгуудыг тавибал найдвартай

# ── Deploy дээр нууцаар (зөвлөмж) ──
# Төслийн хавтаснаас:
#   npx wrangler secret put GOOGLE_AI_API_KEY
# эсвэл:
#   npx wrangler secret put GEMINI_API_KEY
# Дараа нь түлхүүрээ paste → Enter. wrangler.jsonc эсвэл `vars` дотор түлхүүр битгий бич.

# ── Зөвхөн локал (доор нэгийг нь бөглөнө) ──
# GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
TAKE_EXAM_RESULT_WEBHOOK_URL=http://localhost:3002/api/teacher-submission-result
TAKE_EXAM_RESULT_WEBHOOK_SECRET=

# R2 (`/api/r2`) — сурах бичгийн PDF хадгалах/унших үед ашиглана
# Доорх нэрсээс нэг иж бүрдэл байхад хангалттай:
# R2_S3_API=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# эсвэл R2_ENDPOINT=
# эсвэл AWS_ENDPOINT_URL_S3=
#
# R2_ACCESS_KEY_ID=
# эсвэл AWS_ACCESS_KEY_ID=
#
# R2_SECRET_ACCESS_KEY=
# эсвэл AWS_SECRET_ACCESS_KEY=
#
# R2_BUCKET_NAME=
# эсвэл TEXTBOOK_R2_BUCKET=
# эсвэл BOOK_R2_BUCKET_NAME=

# analyzeQuestion model (сонголттой; wrangler.jsonc `vars.GEMINI_ANALYZE_MODEL`-тай нийлнэ)
# GEMINI_ANALYZE_MODEL=gemini-1.5-flash

# Deploy-тай ижил: wrangler.jsonc → vars.LOG_GRAPHQL_GENERATION
# LOG_GRAPHQL_GENERATION=1

# CORS (шаардлагатай бол)
# GRAPHQL_CORS_ORIGINS=http://localhost:3000

# Нууцлал: Gemini түлхүүрийг React/фронт кодонд бүү оруул — зөвхөн backend/Worker.
